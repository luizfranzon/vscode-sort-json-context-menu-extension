{
  "name": "sort-json-context-menu",
  "displayName": "Sort JSON Context Menu",
  "description": "Ordena as chaves de arquivos JSON alfabeticamente direto pelo menu de contexto do Explorer.",
  "version": "0.0.1",
  "icon": "icon.png",
  "publisher": "luizfranzon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luizfranzon/vscode-sort-json-context-menu-extension.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "sort-json-context-menu.sortJson",
        "title": "Sort JSON Alphabetically"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "sort-json-context-menu.sortJson",
          "when": "resourceExtname == .json || explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "check-types": "tsc --noEmit",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^7.0.2"
  }
}
